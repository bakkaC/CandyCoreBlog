---
import '../styles/global.css';
import { formatSchemaDate } from '../lib/content-date';
import { withBase } from '../lib/site-taxonomy';

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  image?: string;
  ogType?: 'website' | 'article';
  publishedTime?: Date | string;
  tags?: string[];
  noindex?: boolean;
}

const { title, description, canonical, image, ogType, publishedTime, tags, noindex } =
  Astro.props;

const normalizedTitle = typeof title === 'string' && title.trim().length ? title.trim() : undefined;
const normalizedDescription =
  typeof description === 'string' && description.trim().length
    ? description.trim()
    : undefined;
const siteName = "Bakka's Blog";
const authorName = 'Bakka';

const pageTitle = normalizedTitle ? `${normalizedTitle} | ${siteName}` : siteName;
const pageDescription =
  normalizedDescription ?? '记录技术成长、分享生活感悟、探索思维边界';
const baseUrl = import.meta.env.BASE_URL;
const withSiteBase = (path: string) => withBase(baseUrl, path);
const homeHref = import.meta.env.DEV ? '/Bakka' : withSiteBase('/');
const navAvatarSrc = withSiteBase('/kumiko.jpg');

const canonicalUrl =
  canonical ??
  (Astro.site ? new URL(Astro.url.pathname, Astro.site).toString() : Astro.url.toString());

const ogImagePath = image ?? '/kumiko.jpg';
const ogImageUrl = Astro.site
  ? new URL(withSiteBase(ogImagePath), Astro.site).toString()
  : withSiteBase(ogImagePath);

const resolvedOgType = ogType ?? 'website';
const publishedISO = formatSchemaDate(publishedTime);
const rssUrl = Astro.site
  ? new URL(withSiteBase('/rss.xml'), Astro.site).toString()
  : withSiteBase('/rss.xml');

const identityUrl = Astro.site ? new URL(withSiteBase('/'), Astro.site).toString() : withSiteBase('/');
const websiteSchema = Astro.site
  ? {
      '@context': 'https://schema.org',
      '@type': 'WebSite',
      name: siteName,
      url: identityUrl,
      inLanguage: 'zh-Hans',
    }
  : undefined;

const pageSchema =
  resolvedOgType === 'article'
    ? {
        '@context': 'https://schema.org',
        '@type': 'BlogPosting',
        headline: normalizedTitle ?? siteName,
        description: pageDescription,
        url: canonicalUrl,
        mainEntityOfPage: { '@type': 'WebPage', '@id': canonicalUrl },
        inLanguage: 'zh-Hans',
        ...(publishedISO ? { datePublished: publishedISO } : {}),
        ...(tags?.length ? { keywords: tags.join(', ') } : {}),
        image: [ogImageUrl],
        author: { '@type': 'Person', name: authorName, url: identityUrl },
      }
    : {
        '@context': 'https://schema.org',
        '@type': 'WebPage',
        name: pageTitle,
        description: pageDescription,
        url: canonicalUrl,
        inLanguage: 'zh-Hans',
      };

const schemas = [websiteSchema, pageSchema].filter(Boolean);

const navCandidates = [
  { label: 'Notes', path: '/notes' },
  { label: 'Thoughts', path: '/thoughts' },
  { label: 'Blogs', path: '/blog' },
];
const currentPath = Astro.url.pathname ?? '/';
const navLinks = navCandidates.map((link) => {
  const href = withSiteBase(link.path);
  const normalizedCurrent = currentPath.endsWith('/') && currentPath.length > 1
    ? currentPath.slice(0, -1)
    : currentPath;
  const normalizedHref = href.endsWith('/') && href.length > 1
    ? href.slice(0, -1)
    : href;
  const isActive =
    normalizedCurrent === normalizedHref ||
    normalizedCurrent.startsWith(`${normalizedHref}/`);
  return { ...link, href, isActive };
});
---

<!doctype html>
<html lang="zh-Hans" class="bg-background text-foreground">
    <head>
      <meta charset="utf-8" />
      <meta name="viewport" content="width=device-width, initial-scale=1" />
      <title>{pageTitle}</title>
      <meta name="description" content={pageDescription} />
      <meta name="author" content={authorName} />
      <meta
        name="robots"
        content={noindex ? 'noindex, nofollow' : 'index, follow'}
      />
      <link rel="canonical" href={canonicalUrl} />

      <meta property="og:title" content={pageTitle} />
      <meta property="og:description" content={pageDescription} />
      <meta property="og:type" content={resolvedOgType} />
      <meta property="og:url" content={canonicalUrl} />
      <meta property="og:site_name" content={siteName} />
      <meta property="og:locale" content="zh_CN" />
      <meta property="og:image" content={ogImageUrl} />

      <meta name="twitter:card" content="summary_large_image" />
      <meta name="twitter:title" content={pageTitle} />
      <meta name="twitter:description" content={pageDescription} />
      <meta name="twitter:image" content={ogImageUrl} />

      {resolvedOgType === 'article' && publishedISO ? (
        <meta property="article:published_time" content={publishedISO} />
      ) : null}
      {resolvedOgType === 'article' && tags?.length
        ? tags.map((tag) => <meta property="article:tag" content={tag} />)
        : null}

      <link
        rel="alternate"
        type="application/rss+xml"
        title={`${siteName} RSS`}
        href={rssUrl}
      />

      <script
        type="application/ld+json"
        set:html={JSON.stringify(schemas)}
        is:inline
      />
      <link rel="preconnect" href="https://fonts.googleapis.com" />
      <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
      <link
        rel="stylesheet"
        href="https://db.onlinewebfonts.com/c/2a2b767302dad0d292294c13d63a0c5f?family=DIN+2014"
      />
      <link rel="icon" type="image/jpeg" href={withSiteBase('/kumiko.jpg')} />
      {navLinks.map((link) => (
        <link rel="prefetch" href={link.href} />
      ))}
    </head>
    <body class="min-h-screen bg-background text-foreground">
      <header class="sticky top-0 z-50 bg-background/80 backdrop-blur">
        <div class="mx-auto flex w-full max-w-7xl items-center justify-between px-6 py-4">
          <a href={homeHref} class="inline-flex items-center gap-3 font-sans text-base font-bold sm:text-lg">
            <img
              src={navAvatarSrc}
              alt=""
              aria-hidden="true"
              class="h-8 w-8 rounded-full object-cover ring-1 ring-slate-200"
            />
            <span>{siteName}</span>
          </a>
          <nav class="font-sans flex items-center gap-6 text-xs font-medium md:text-sm">
            {navLinks.map((link) => (
              <a
                class="font-medium hover:text-primary"
                href={link.href}
                rel="prefetch"
                aria-current={link.isActive ? 'page' : undefined}
              >
                {link.label}
              </a>
            ))}
          </nav>
        </div>
      </header>
    <main class="min-h-[calc(100vh-80px)]">
      <slot />
    </main>
  </body>
</html>
