---
import { normalizeTag, slugifyTag, withBase } from '../../lib/site-taxonomy';

interface Props {
  tags?: string[];
  className?: string;
  baseUrl?: string;
}

const { tags = [], className, baseUrl = import.meta.env.BASE_URL } = Astro.props;
const normalizedTags = [...new Set(tags.map(normalizeTag).filter(Boolean))];
---

{
  normalizedTags.length ? (
    <ul class:list={['flex flex-wrap gap-2', className]}>
      {normalizedTags.map((tag) => (
        <li>
          <a
            href={withBase(baseUrl, `/tag/${slugifyTag(tag)}`)}
            class="inline-flex items-center rounded-full border border-stone-300/70 bg-stone-100 px-3 py-1 text-xs font-medium text-stone-700 transition-colors hover:border-stone-400 hover:bg-stone-200"
          >
            #{tag}
          </a>
        </li>
      ))}
    </ul>
  ) : null
}
