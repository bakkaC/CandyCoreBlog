---
import type { CollectionEntry } from 'astro:content';

import { FilesystemItem } from '../ui/filesystem-item';
import { formatContentDate, getContentDateTimestamp } from '../../lib/content-date';
import { getEntryPath, withBase } from '../../lib/site-taxonomy';

interface Props {
  title: string;
  subtitle: string;
  entries: CollectionEntry<'notes' | 'thoughts' | 'blogs'>[];
  baseUrl: string;
  rootPath: string;
  accent?: string;
  archiveLabel?: string;
  titleClassName?: string;
  headerTheme?: 'light' | 'dark';
  backButtonTheme?: 'light' | 'dark';
  panelClassName?: string;
  overlayClassName?: string;
  hoverTextClassName?: string;
}

const {
  title,
  subtitle,
  entries,
  baseUrl,
  rootPath,
  accent: accentOverride,
  archiveLabel = 'archive',
  titleClassName,
  headerTheme = 'light',
  backButtonTheme = 'light',
  panelClassName,
  overlayClassName = 'bg-black/10',
  hoverTextClassName = 'group-hover:text-accent',
} = Astro.props;
const withSiteBase = (path: string) => withBase(baseUrl, path);
const isDarkHeader = headerTheme === 'dark';
const isDarkBackButton = backButtonTheme === 'dark';

const accentThemes = [
  { path: '/notes', accent: '#60a5fa' },
  { path: '/thoughts', accent: '#fcd34d' },
  { path: '/blog', accent: '#f87171' },
];

const matchedTheme = accentThemes.find((theme) => theme.path === rootPath);
const accent = accentOverride ?? matchedTheme?.accent ?? '#60a5fa';
const accentBackground = accent;

type ContentEntry = CollectionEntry<'notes' | 'thoughts' | 'blogs'>;

type FilesystemNode = {
  id: string;
  kind: 'entry' | 'folder';
  name: string;
  title: string;
  href?: string;
  index?: string;
  meta?: string;
  nodes?: FilesystemNode[];
  sortTimestamp: number;
};

const createEntryNode = (entry: ContentEntry): FilesystemNode => ({
  id: entry.id,
  kind: 'entry',
  name: entry.id.split('/').at(-1) ?? entry.id,
  href: withSiteBase(getEntryPath(entry)),
  title: entry.data.title ?? entry.id.split('/').at(-1) ?? entry.id,
  meta: formatContentDate(entry.data.date),
  sortTimestamp: getContentDateTimestamp(entry.data.date),
});

const getNodeSortTimestamp = (node: FilesystemNode) => {
  if (node.kind === 'entry') {
    return node.sortTimestamp;
  }

  const childTimestamp = Math.max(0, ...(node.nodes ?? []).map(getNodeSortTimestamp));
  return Math.max(node.sortTimestamp, childTimestamp);
};

const compareNodes = (a: FilesystemNode, b: FilesystemNode) => {
  const aDate = getNodeSortTimestamp(a);
  const bDate = getNodeSortTimestamp(b);
  if (aDate !== bDate) return bDate - aDate;

  return a.title.localeCompare(b.title, 'zh-Hans');
};

const sortTree = (nodes: FilesystemNode[]): FilesystemNode[] =>
  [...nodes]
    .map((node) =>
      node.kind === 'folder' && node.nodes
        ? {
            ...node,
            nodes: sortTree(node.nodes),
          }
        : node
    )
    .sort(compareNodes);

const inheritFolderMeta = (nodes: FilesystemNode[]): FilesystemNode[] =>
  nodes.map((node) => {
    if (node.kind !== 'folder' || !node.nodes) {
      return node;
    }

    const nextNodes = inheritFolderMeta(node.nodes);
    const latestChild = nextNodes.reduce<FilesystemNode | undefined>((latest, child) => {
      if (!latest) {
        return child;
      }

      return getNodeSortTimestamp(child) > getNodeSortTimestamp(latest) ? child : latest;
    }, undefined);

    if (node.href) {
      return {
        ...node,
        nodes: nextNodes,
      };
    }

    return {
      ...node,
      nodes: nextNodes,
      meta: latestChild?.meta,
      sortTimestamp: Math.max(node.sortTimestamp, getNodeSortTimestamp(latestChild ?? node)),
    };
  });

const assignEntryIndexes = (nodes: FilesystemNode[]): FilesystemNode[] => {
  let entryIndex = 0;

  return nodes.map((node) => {
    if (node.kind === 'folder' && !node.href) {
      return {
        ...node,
        index: undefined,
        nodes: node.nodes ? assignEntryIndexes(node.nodes) : node.nodes,
      };
    }

    entryIndex += 1;
    return {
      ...node,
      index: String(entryIndex).padStart(2, '0'),
      nodes: node.kind === 'folder' && node.nodes ? assignEntryIndexes(node.nodes) : node.nodes,
    };
  });
};

const folderPaths = new Set(
  entries.flatMap((entry) => {
    const segments = entry.id.split('/');
    return segments.slice(0, -1).map((_, index) => segments.slice(0, index + 1).join('/'));
  })
);

const rootNodes: FilesystemNode[] = [];
const folderNodeMap = new Map<string, FilesystemNode>();

const ensureFolderNode = (segments: string[]) => {
  const folderId = segments.join('/');
  const existing = folderNodeMap.get(folderId);
  if (existing) {
    return existing;
  }

  const node: FilesystemNode = {
    id: folderId,
    kind: 'folder',
    name: segments.at(-1) ?? folderId,
    title: segments.at(-1) ?? folderId,
    nodes: [],
    sortTimestamp: 0,
  };

  folderNodeMap.set(folderId, node);

  if (segments.length === 1) {
    rootNodes.push(node);
    return node;
  }

  const parentNode = ensureFolderNode(segments.slice(0, -1));
  parentNode.nodes ??= [];
  parentNode.nodes.push(node);
  return node;
};

for (const entry of entries) {
  const segments = entry.id.split('/');
  const entryNode = createEntryNode(entry);

  if (folderPaths.has(entry.id)) {
    const folderNode = ensureFolderNode(segments);
    folderNode.href = entryNode.href;
    folderNode.title = entryNode.title;
    folderNode.meta = entryNode.meta;
    folderNode.sortTimestamp = entryNode.sortTimestamp;
    continue;
  }

  if (segments.length === 1) {
    rootNodes.push(entryNode);
    continue;
  }

  const parentNode = ensureFolderNode(segments.slice(0, -1));
  parentNode.nodes ??= [];
  parentNode.nodes.push(entryNode);
}

const listNodes = assignEntryIndexes(inheritFolderMeta(sortTree(rootNodes)));
---

<section
  class="relative min-h-[calc(100vh-80px)] overflow-hidden bg-(--accent-bg) text-stone-900"
  style={`--accent: ${accent}; --accent-bg: ${accentBackground};`}
>
  <div
    aria-hidden="true"
    class:list={['pointer-events-none absolute inset-0 z-0', overlayClassName]}
  />
  <div
    aria-hidden="true"
    class="viewport-frame"
  />
  <div class="relative z-10 mx-auto w-full max-w-4xl px-8 pt-6 pb-12 sm:max-w-5xl sm:px-6 sm:py-16 lg:px-10">
    <div class="flex flex-col gap-6">
      <div class="max-w-2xl">
        <p class:list={['text-[0.6rem] uppercase sm:text-xs', isDarkHeader ? 'text-stone-700' : 'text-white']}>{archiveLabel}</p>
        <h1 class:list={['mt-3 text-4xl font-semibold tracking-tight sm:text-6xl lg:text-7xl', isDarkHeader ? 'text-stone-900' : 'text-white', titleClassName]}>
          {title}
        </h1>
        <p class:list={['mt-2 text-sm leading-relaxed sm:text-base', isDarkHeader ? 'text-stone-700' : 'text-stone-200']}>
          {subtitle}
        </p>
      </div>

      <div class:list={['mt-6 border border-stone-200 bg-slate-50 p-4 shadow-[0_20px_60px_-40px_rgba(0,0,0,0.25)] sm:p-6', panelClassName]}>
        <div class="flex items-center justify-between text-xs uppercase tracking-[0.2em] text-stone-500">
          <span>Title</span>
          <span>Date</span>
        </div>

        <div class="mono-latin-songti-cjk mt-6 text-[0.9rem] sm:text-[0.95rem]">
          {listNodes.length ? (
            <ul>
              {listNodes.map((node) => (
                <FilesystemItem
                  client:load
                  animated={true}
                  showIcons={false}
                  showToggles={false}
                  toggleTrigger="folder"
                  defaultOpen={true}
                  node={node}
                  itemClassName="py-3"
                  linkClassName="group flex-col gap-2 transition hover:translate-x-1"
                  hoverTextClassName={hoverTextClassName}
                />
              ))}
            </ul>
          ) : (
            <p class="py-6 text-sm text-stone-600">No entries yet.</p>
          )}
        </div>
      </div>

      <div class="mt-6 text-xs uppercase sm:text-sm">
        <a
          href={withSiteBase('/')}
          class:list={[
            'group relative inline-flex items-center gap-2 overflow-hidden border px-3 py-2 transition-colors duration-300',
            isDarkBackButton
              ? 'border-stone-900 text-stone-900 hover:text-white'
              : 'border-white text-white hover:text-stone-900',
          ]}
        >
          <span
            aria-hidden="true"
            class:list={[
              'absolute inset-0 -translate-x-full transition-transform duration-300 group-hover:translate-x-0',
              isDarkBackButton ? 'bg-stone-900' : 'bg-white',
            ]}
          />
          <span class="relative z-10">&larr; back to home</span>
        </a>
      </div>
    </div>
  </div>
</section>
