---
interface Props {
  className?: string;
  columns?: 2 | 3;
  gap?: 'lg' | 'md' | 'sm';
}

const {
  className = '',
  columns = 2,
  gap = 'md',
} = Astro.props as Props;

const columnsClass = columns === 3 ? 'md:grid-cols-3' : 'md:grid-cols-2';
const gapClass =
  gap === 'sm' ? 'gap-4' : gap === 'lg' ? 'gap-8' : 'gap-6';
---

<div
  class={`content-columns not-prose my-8 grid grid-cols-1 ${columnsClass} ${gapClass} ${className}`.trim()}
>
  <slot />
</div>

<style>
  .content-columns > * {
    min-width: 0;
    margin: 0;
  }

  .content-columns > :is(div, section, article) {
    border: 1px solid color-mix(in oklab, var(--color-border) 75%, white 25%);
    border-radius: var(--radius-xl);
    background:
      linear-gradient(
        180deg,
        color-mix(in oklab, white 94%, var(--color-muted) 6%),
        color-mix(in oklab, white 88%, var(--color-muted) 12%)
      );
    box-shadow: 0 18px 40px rgb(15 23 42 / 0.06);
    padding: 1.1rem 1.15rem;
  }

  .content-columns > * > :first-child {
    margin-top: 0;
  }

  .content-columns > * > :last-child {
    margin-bottom: 0;
  }

  .content-columns > figure {
    width: 100%;
  }

  .content-columns > figure :global(button) {
    width: 100%;
  }

  .content-columns :global(img) {
    width: 100%;
  }

  @media (min-width: 640px) {
    .content-columns > :is(div, section, article, figure) {
      padding: 1.35rem 1.4rem;
    }
  }
</style>
