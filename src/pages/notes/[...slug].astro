---
import BaseLayout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';
import EntryTags from '../../components/collection/EntryTags.astro';
import { mdxComponents } from '../../components/content/mdx-components';
import { formatContentDate } from '../../lib/content-date';

export async function getStaticPaths() {
  const entries = await getCollection('notes');
  return entries.map((entry) => ({
    params: { slug: entry.id },
  }));
}

const { slug } = Astro.params;
const entries = await getCollection('notes');
const entry = entries.find((item) => item.id === slug);
if (!entry) {
  throw new Error(`Note not found: ${slug}`);
}

const { Content } = await render(entry);
const baseUrl = import.meta.env.BASE_URL;
---

<BaseLayout
  title={entry.data.title ?? entry.id}
  description={entry.data.description}
  ogType="article"
  publishedTime={entry.data.date}
  tags={entry.data.tags}
>
  <article class="mx-auto w-full max-w-4xl px-6 py-12">
    <div class="mb-8">
      <h1 class="text-3xl font-bold">
        {entry.data.title ?? entry.id}
      </h1>
      {entry.data.date ? (
        <p class="mt-2 text-sm text-muted-foreground">
          {formatContentDate(entry.data.date)}
        </p>
      ) : null}
      {entry.data.tags?.length ? (
        <EntryTags tags={entry.data.tags} className="mt-4" baseUrl={baseUrl} />
      ) : null}
    </div>
    <div class="markdown">
      <Content components={mdxComponents} />
    </div>
  </article>
</BaseLayout>
