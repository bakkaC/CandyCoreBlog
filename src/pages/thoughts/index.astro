---
import BaseLayout from '../../layouts/Layout.astro';
import ArticleList from '../../components/collection/ArticleList.astro';
import { getCollection } from 'astro:content';
import { getContentDateTimestamp } from '../../lib/content-date';

const entries = await getCollection('thoughts');
const sorted = [...entries].sort((a, b) => {
  const aDate = getContentDateTimestamp(a.data.date);
  const bDate = getContentDateTimestamp(b.data.date);
  if (aDate !== bDate) return bDate - aDate;
  return a.id.localeCompare(b.id, 'zh-Hans');
});

const baseUrl = import.meta.env.BASE_URL;
---

<BaseLayout title="Thoughts" description="洞察思考文章列表">
  <ArticleList
    title="Thoughts"
    subtitle="洞察思考与随笔"
    entries={sorted}
    baseUrl={baseUrl}
    rootPath="/thoughts"
  />
</BaseLayout>
