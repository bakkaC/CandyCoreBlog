---
import { getCollection } from 'astro:content';

import BaseLayout from '../layouts/Layout.astro';
import HomePage from '../components/pages/HomePage';
import { formatContentDate } from '../lib/content-date';
import {
  COLLECTION_ROOTS,
  collectTagBuckets,
  normalizeTag,
  sortEntriesByDate,
  withBase,
} from '../lib/site-taxonomy';

const baseUrl = import.meta.env.BASE_URL;
const [notes, thoughts, blogs] = await Promise.all([
  getCollection('notes'),
  getCollection('thoughts'),
  getCollection('blogs'),
]);

const entries = sortEntriesByDate([...notes, ...thoughts, ...blogs]);
const tagBuckets = collectTagBuckets(entries);

const latestPosts = entries.slice(0, 5).map((entry) => ({
  title: entry.data.title ?? entry.id,
  href: withBase(baseUrl, `${COLLECTION_ROOTS[entry.collection]}/${entry.id}`),
  dateLabel: formatContentDate(entry.data.date),
  collection: entry.collection,
  tags: [...new Set((entry.data.tags ?? []).map(normalizeTag).filter(Boolean))],
}));

const categories = tagBuckets.slice(0, 28).map((bucket) => ({
  tag: bucket.tag,
  count: bucket.count,
  href: withBase(baseUrl, `/tag/${bucket.slug}`),
}));
---

<BaseLayout>
  <HomePage
    baseUrl={baseUrl}
    latestPosts={latestPosts}
    categories={categories}
    client:load
  />
</BaseLayout>
